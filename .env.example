# ===== LINE Messaging API (เปิด OA ใหม่สำหรับ EunJod) =====
# LINE Developers Console → Messaging API channel
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ===== Supabase =====
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Claude (จัดหมวดคำใหม่ — ไม่ใส่ก็ทำงานได้ แค่ไม่มี AI fallback) =====
ANTHROPIC_API_KEY=
# โมเดลจัดหมวด (ค่าเริ่มต้น Haiku — ถูกและเร็ว)
EUNJOD_CATEGORIZE_MODEL=claude-haiku-4-5-20251001

# ===== เว็บรายงาน =====
# โดเมนสาธารณะของแอป (ใช้สร้างลิงก์รายงาน) เช่น https://eunjod.vercel.app
APP_BASE_URL=http://localhost:3000
